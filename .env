# Provider: REPLICATE | STABILITY | OPENAI
IMAGE_PROVIDER=REPLICATE

# Replicate example
REPLICATE_API_TOKEN=replicate_token_here

# StabilityAI example
STABILITY_API_KEY=stability_key_here

# OpenAI example (if using DALL·E / images)
OPENAI_API_KEY=openai_key_here

# AWS S3
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=yyy
AWS_BUCKET_NAME=my-avatar-bucket
AWS_REGION=us-east-1

# Redis & Postgres
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/avatar_db
